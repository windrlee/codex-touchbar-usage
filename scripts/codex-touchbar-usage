#!/usr/bin/env python3
import json
import os
import selectors
import subprocess
import sys
import time
from datetime import datetime, timedelta
from pathlib import Path


CODEX_BIN = "/Applications/ChatGPT.app/Contents/Resources/codex"
CACHE_PATH = Path.home() / "Library/Caches/CodexTouchBar/usage.json"


def fmt_usage(value, width=10):
    if value is None:
        return "--"

    percent = min(100.0, max(0.0, float(value)))
    filled = int(percent * width / 100 + 0.5)
    rail = "━" * filled + "─" * (width - filled)
    return f"{percent:.0f}% {rail}"


def fmt_reset(value):
    if not value:
        return "--"

    reset_at = datetime.fromtimestamp(int(value))
    now = datetime.now()
    tomorrow = now.date() + timedelta(days=1)

    if reset_at.date() == now.date():
        return reset_at.strftime("%H:%M")
    if reset_at.date() == tomorrow:
        return "明" + reset_at.strftime("%H:%M")
    return reset_at.strftime("%m/%d %H:%M")


def fmt_title(weekly_usage, weekly_reset, cached_age=None):
    prefix = "⚠ " if cached_age is not None else ""
    suffix = f" ·{format_cache_age(cached_age)}" if cached_age is not None else ""
    return f"{prefix}1w {weekly_usage} ↻{weekly_reset}{suffix}"


def format_cache_age(seconds):
    minutes = max(0, int(seconds or 0) // 60)
    return "<1m" if minutes == 0 else f"{minutes}m"


def save_cached_payload(payload):
    try:
        CACHE_PATH.parent.mkdir(parents=True, exist_ok=True)
        temp_path = CACHE_PATH.with_suffix(".tmp")
        temp_path.write_text(
            json.dumps({"saved_at": time.time(), "payload": payload}),
            encoding="utf-8",
        )
        os.replace(temp_path, CACHE_PATH)
    except Exception:
        pass


def load_cached_payload():
    try:
        cached = json.loads(CACHE_PATH.read_text(encoding="utf-8"))
        saved_at = float(cached["saved_at"])
        payload = cached["payload"]
        if not isinstance(payload, dict):
            return None
        return payload, max(0, time.time() - saved_at)
    except Exception:
        return None


def normalize_rpc_rate_limits(result):
    if not result:
        return None

    by_id = result.get("rateLimitsByLimitId") or {}
    snapshot = by_id.get("codex") or result.get("rateLimits") or {}
    primary = snapshot.get("primary") or {}
    if primary.get("usedPercent") is None and primary.get("resetsAt") is None:
        return None

    return {
        "rate_limits": {
            "primary": {
                "used_percent": primary.get("usedPercent"),
                "resets_at": primary.get("resetsAt"),
            }
        }
    }


def read_rpc_response(process, selector, request_id, timeout):
    deadline = time.time() + timeout
    while time.time() < deadline:
        events = selector.select(timeout=0.1)
        for key, _ in events:
            line = key.fileobj.readline()
            if not line:
                continue
            if key.fileobj is process.stderr:
                continue
            try:
                obj = json.loads(line)
            except Exception:
                continue
            if obj.get("id") == request_id:
                return obj
    return None


def fetch_rate_limits_from_codex_rpc(timeout=3.0):
    process = None
    try:
        process = subprocess.Popen(
            [CODEX_BIN, "-s", "read-only", "-a", "untrusted", "app-server"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        selector = selectors.DefaultSelector()
        selector.register(process.stdout, selectors.EVENT_READ)
        selector.register(process.stderr, selectors.EVENT_READ)

        def send(request):
            process.stdin.write(json.dumps(request, separators=(",", ":")) + "\n")
            process.stdin.flush()

        send(
            {
                "id": 1,
                "method": "initialize",
                "params": {
                    "clientInfo": {
                        "name": "codex-touchbar-usage",
                        "version": "1",
                    },
                    "protocolVersion": 2,
                },
            }
        )
        if not read_rpc_response(process, selector, 1, timeout):
            return None

        send({"method": "initialized", "params": {}})
        send({"id": 2, "method": "account/rateLimits/read", "params": None})
        response = read_rpc_response(process, selector, 2, timeout)
        if not response or response.get("error"):
            return None
        return normalize_rpc_rate_limits(response.get("result"))
    except Exception:
        return None
    finally:
        if process:
            try:
                if process.stdin:
                    process.stdin.close()
            except Exception:
                pass
            try:
                process.terminate()
                process.wait(timeout=0.5)
            except Exception:
                try:
                    process.kill()
                except Exception:
                    pass


def main():
    payload = fetch_rate_limits_from_codex_rpc()
    if not payload:
        cached = load_cached_payload()
        if not cached:
            print("Codex RPC --")
            return 0
        payload, cached_age = cached
    else:
        save_cached_payload(payload)
        cached_age = None

    if not payload:
        print("Codex RPC --")
        return 0

    limits = payload.get("rate_limits") or {}
    weekly = limits.get("primary") or {}

    weekly_usage = fmt_usage(weekly.get("used_percent"))
    weekly_reset = fmt_reset(weekly.get("resets_at"))

    print(fmt_title(weekly_usage, weekly_reset, cached_age))
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception:
        print("Codex RPC --")
        sys.exit(0)
